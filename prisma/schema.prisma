generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Unit {
  id                  String  @id
  name                String
  name_plural         String
  speed               Int
  attack              Int
  description         String
  resources_wood      Int?
  resources_stone     Int?
  resources_iron      Int?
  favor               Int
  population          Int
  build_time          Int
  god_id              String?
  is_naval            Boolean
  unit_function       String
  category            String
  is_npc_unit_only    Boolean
  def_hack            Int
  def_pierce          Int
  def_distance        Int
  booty               Int?
  infantry            Boolean?
  flying              Boolean?
  attack_type         String?
  capacity            Int?
}

model Report {
  id             String   @id @default(uuid())
  originalId     String?  // The GRCT report ID if applicable
  attacker       String
  attackerTown   String?
  defender       String
  defenderTown   String?
  date           DateTime
  morale         Int?
  luck           Int?
  lootedWood     Int      @default(0)
  lootedStone    Int      @default(0)
  lootedIron     Int      @default(0)
  createdAt      DateTime @default(now())
}

model Island {
  id            Int    @id
  x             Int
  y             Int
  type          Int
  availableTowns Int
  resourcePlus  String
  resourceMinus String
}

model Player {
  id         Int    @id
  name       String
  allianceId Int?
  points     Int
  rank       Int
  towns      Int
  townsList  Town[]
  alliance   Alliance? @relation(fields: [allianceId], references: [id])
}

model PlayerHistory {
  id        Int      @id @default(autoincrement())
  playerId  Int
  oldPoints Int
  newPoints Int
  timestamp DateTime @default(now())
}

model Alliance {
  id      Int    @id
  name    String
  points  Int
  towns   Int
  members Int
  rank    Int
  players Player[]
}

model AllianceHistory {
  id         Int      @id @default(autoincrement())
  allianceId Int
  oldPoints  Int
  newPoints  Int
  timestamp  DateTime @default(now())
}

model Town {
  id       Int    @id
  playerId Int?
  name     String
  islandX  Int
  islandY  Int
  islandSlot Int
  points   Int
  player   Player? @relation(fields: [playerId], references: [id])
}

model TownHistory {
  id        Int      @id @default(autoincrement())
  townId    Int
  oldPoints Int
  newPoints Int
  timestamp DateTime @default(now())
}

model SyncMetadata {
  id          Int      @id @default(1)
  lastSync    DateTime @default(now())
  geoJsonCache String? @db.Text
}
